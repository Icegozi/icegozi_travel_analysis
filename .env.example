# Cấu hình chạy tự động. Không đặt mật khẩu hay API key trong tệp này.

# 1 = chạy crawler, 0 = bỏ qua crawler tương ứng.
RUN_VNTRIP_CRAWLER=1
RUN_VIETNAM_TRAVEL_CRAWLER=1
RUN_PORTALS_CRAWLER=0

# Giới hạn thu thập mỗi lần chạy. Tôn trọng robots.txt và không tăng quá nhanh.
VNTRIP_MAX_PAGES=50
VNTRIP_MAX_NEW_ARTICLES=1000
VIETNAM_TRAVEL_MAX_PAGES=50
VIETNAM_TRAVEL_MAX_NEW_ARTICLES=1000
PORTALS_MAX_NEW_ARTICLES=100
PORTALS_MAX_PAGES=20
PORTALS_DELAY_SECONDS=2

# Khoảng nghỉ giữa các request (giây) và thời gian chờ HTTP (giây).
VNTRIP_DELAY_SECONDS=2
VIETNAM_TRAVEL_DELAY_SECONDS=2
HTTP_TIMEOUT_SECONDS=3
HTTP_RETRIES=2

# Có thể để trống để run_all.sh tự dùng .venv/bin/python.
PYTHON_BIN=
